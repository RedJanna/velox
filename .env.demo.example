# ============================================================
# Velox Local Demo Environment
# Copy this file to .env.demo.local before starting the demo stack
# ============================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_PORT=8011
APP_HOST=0.0.0.0
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-local-demo
APP_TRUSTED_HOSTS=127.0.0.1,localhost
PUBLIC_BASE_URL=http://127.0.0.1:8011
ADMIN_PANEL_PATH=/admin
PHONE_HASH_SALT=replace-with-local-demo-salt

# --- Database (container-internal connectivity) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=velox_demo
DB_USER=velox
DB_PASSWORD=change-me-demo
DB_POOL_MIN=5
DB_POOL_MAX=20

# --- Redis (container-internal connectivity) ---
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_TTL_SECONDS=1800
REDIS_RATE_LIMIT_TTL_SECONDS=60
METRICS_ALLOW_PUBLIC=false
METRICS_ALLOWED_CIDRS=127.0.0.1/32,::1/128

# --- OpenAI ---
OPENAI_API_KEY=sk-demo-placeholder
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.3

# --- Operation Mode ---
OPERATION_MODE=test

# --- Meta WhatsApp Business API ---
WHATSAPP_API_VERSION=v21.0
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Elektraweb PMS ---
ELEKTRA_API_BASE_URL=
ELEKTRA_API_KEY=
ELEKTRA_HOTEL_ID=21966
ELEKTRA_GENERIC_API_BASE_URL=https://4001.hoteladvisor.net
ELEKTRA_GENERIC_LOGIN_TOKEN=
ELEKTRA_GENERIC_TENANT=
ELEKTRA_GENERIC_USERCODE=
ELEKTRA_GENERIC_PASSWORD=

# --- Admin Panel ---
ADMIN_JWT_SECRET=change-me-demo-jwt-secret
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRE_MINUTES=60
ADMIN_WEBHOOK_SECRET=change-me-demo-webhook-secret
ADMIN_BOOTSTRAP_TOKEN=local-demo-bootstrap-token
ADMIN_TOTP_ISSUER=NexlumeAI Demo
CLOUDFLARE_TUNNEL_TOKEN=

# --- Rate Limiting ---
RATE_LIMIT_PER_PHONE_PER_MINUTE=30
RATE_LIMIT_PER_PHONE_PER_HOUR=200
RATE_LIMIT_WEBHOOK_PER_MINUTE=100

# --- Inbound Media Analysis ---
MEDIA_ANALYSIS_ENABLED=true
MEDIA_MAX_BYTES=8388608
MEDIA_MAX_IMAGE_DIMENSION=2048
MEDIA_RETENTION_HOURS=24
MEDIA_SUPPORTED_MIME_TYPES=image/jpeg,image/jpg,image/png,image/webp,image/tiff,image/heic,image/heif
AUDIO_TRANSCRIPTION_ENABLED=true
AUDIO_MAX_BYTES=16777216
AUDIO_SUPPORTED_MIME_TYPES=audio/ogg,audio/oga,audio/mpeg,audio/mp3,audio/mp4,audio/aac,audio/amr,audio/wav,audio/x-wav,audio/webm
AUDIO_TRANSCRIPTION_MIN_CONFIDENCE=0.55
AUDIO_TRANSCRIPTION_FALLBACK_LANGUAGE=en

# --- Hotel Config ---
HOTEL_PROFILES_DIR=data/hotel_profiles
ESCALATION_MATRIX_PATH=data/escalation_matrix.yaml
TEMPLATES_DIR=data/templates
SCENARIOS_DIR=data/scenarios
